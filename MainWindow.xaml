<Window x:Class="HLL_SPA_calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPA Calculator"

        Height="448"
        Width="400"

        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"

        Topmost="True">

    <Grid Margin="20"
      Background="#CC1E1E1E">


        <Border Background="#DD1E1E1E"
            CornerRadius="12"
            Padding="20">

         <StackPanel>

            <TextBlock
                Text="Vehicle"
                Foreground="#BB86FC"
                Margin="0,0,0,5"/>

            <ComboBox
                Name="ArtilleryComboBox"
                Height="30"
                Margin="0,0,0,15"/>

            <TextBlock
                Text="Target Distance (m)"
                Foreground="#BB86FC"
                Margin="0,0,0,5"/>

            <TextBox
                Name="DistanceTextBox"
                Height="30"
                Margin="0,0,0,15"/>

            <TextBlock
    Text="Angle Offset (mil)"
            Foreground="#BB86FC"
    Margin="0,0,0,5"/>

            <TextBox
    Name="SlopeOffsetTextBox"
    Height="30"
    Margin="0,0,0,15"/>
                <TextBlock
    Text="Bias"
          Foreground="#BB86FC"
    Margin="0,0,0,5"/>

                <TextBox
    Name="BiasTextBox"
    Height="30"
    Margin="0,0,0,15"/>

                <Button
                Content="Calculate"
                Height="35"
                Click="Calculate_Click"/>

            <TextBlock
                Name="ResultTextBlock"
                Foreground="#BB86FC"
                Margin="0,20,0,0"
                FontSize="20"/>
        </StackPanel>
        </Border>
    </Grid>
</Window>